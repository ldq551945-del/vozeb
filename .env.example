NEXT_PUBLIC_SITE_URL=https://your-vozeb-domain.example
NEXT_PUBLIC_DOC_URL=https://github.com/csyqlz/vozeb/tree/main/docs
VOZEB_COOKIE_SECURE=true
# Default 0.0.0.0 supports both http://server-ip:3000 and domain reverse proxy.
# Use 127.0.0.1 when you only want access through a local reverse proxy.
VOZEB_BIND_HOST=0.0.0.0
